# Marksys appliance configuration.
# Copy to /etc/marksys/appliance.env and edit. Do NOT commit the real file.

# --- backup_db.sh -----------------------------------------------------------
# Where the app's secrets live (same TOML the app reads; [connections.postgresql]).
SECRETS_FILE=/etc/marksys/secrets.toml

# Where local database dumps are written.
BACKUP_DIR=/var/backups/marksys

# Delete dumps older than this many days (0 = keep forever).
RETENTION_DAYS=30

# Supabase requires SSL. Leave as 'require' unless you know otherwise.
PGSSLMODE=require

# Optional: mount point of a USB stick to also copy the newest dump onto.
# Leave empty to disable. Example: /media/marksys/BACKUP
USB_MOUNT=

# --- app / kiosk ------------------------------------------------------------
# Public cloud URL the kiosk browser opens. In Tier 1 the app stays on the
# cloud; the appliance is a dedicated client + control/backup station.
APP_URL=https://your-app.example.com

# Per-mode URLs. Leave unset to use APP_URL for both.
#   PRACTICE_URL — 日常練習：一般開 app 首頁。
#   CONTEST_URL  — 比賽日：如果部機接住投影機做大屏，設成投影顯示頁：
#                  https://your-app.example.com/projector
#                  （主席／IT 另用自己裝置開 .../projector/control 控制；
#                   時間仍然喺主席裝置嘅 app，投影唔顯示時間。）
PRACTICE_URL=
CONTEST_URL=

# Seconds to wait at the boot chooser before defaulting to 日常練習.
# 0 = wait forever (operator must pick).
CHOOSER_TIMEOUT=0

# Local proxy port, only relevant if you ever host the app on the appliance.
APP_PORT=8000

# --- health light (health_check.sh + health_overlay.py) ---------------------
# Where the health snapshot JSON is written / read.
HEALTH_FILE=/var/lib/marksys/health.json

# Disk free-space thresholds (percent of root filesystem).
DISK_WARN_PCT=15
DISK_FAIL_PCT=5

# Backup is flagged amber if the newest good backup is older than this.
BACKUP_WARN_HOURS=26
